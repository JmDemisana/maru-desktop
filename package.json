{
  "name": "maru-desktop",
  "version": "0.0.1",
  "description": "Maru Desktop - Offline applet shell",
  "author": "Maru",
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "start": "electron .",
    "build": "echo 'Web assets built in main repo, copy desktop-web-dist/ here first'",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "io.maru.desktop",
    "productName": "Maru Desktop",
    "artifactName": "Maru-Desktop-${os}-${arch}.${ext}",
    "npmRebuild": false,
    "files": [
      "desktop-web-dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "public",
      "output": "desktop-dist"
    },
    "win": {
      "icon": "public/app-icon.png",
      "target": [
        {
          "target": "portable",
          "arch": ["ia32"]
        },
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["arm64"]
        },
        {
          "target": "msix",
          "arch": ["x64"]
        }
      ]
    },
    "linux": {
      "icon": "public/app-icon.png",
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    },
    "mac": {
      "icon": "public/app-icon.png",
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64"]
        }
      ],
      "category": "public.app-category.utilities"
    }
  },
  "devDependencies": {
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1"
  }
}